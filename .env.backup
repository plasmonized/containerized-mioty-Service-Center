# TLS Server Configuration
LISTEN_HOST=0.0.0.0
LISTEN_PORT=16018

# SSL/TLS Certificate Configuration
CERT_FILE=certs/service_center_cert.pem
KEY_FILE=certs/service_center_key.pem
CA_FILE=certs/ca_cert.pem

# MQTT Configuration
MQTT_BROKER=akahlig.selfhost.co
MQTT_PORT=1887
MQTT_USERNAME=bssci
MQTT_PASSWORD=test=1234
BASE_TOPIC=bssci

# Application Configuration
SENSOR_CONFIG_FILE=endpoints.json
STATUS_INTERVAL=30
DEDUPLICATION_DELAY=2

# Web Interface Configuration
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# Auto-detach Configuration - KORREKTE WERTE 6h/3h/1h
AUTO_DETACH_ENABLED=true
AUTO_DETACH_TIMEOUT=21600
AUTO_DETACH_WARNING_TIMEOUT=10800
AUTO_DETACH_CHECK_INTERVAL=3600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/bssci_service.log

# Security
SECRET_KEY=your-secret-key-here